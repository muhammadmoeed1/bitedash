DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
PORT=6006
NODE_ENV=development
# Comma-separated list of allowed origins, or "*" to allow any origin (default)
CORS_ORIGIN=*

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=<random-secret-at-least-16-chars>
JWT_REFRESH_SECRET=<different-random-secret-at-least-16-chars>
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Optional — payments respond with 503 "not configured" until these are set. Get test-mode
# keys free at https://dashboard.stripe.com/test/apikeys (no real account/business needed).
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen --forward-to localhost:6006/api/v1/payments/webhook` (Stripe CLI) in dev,
# or the webhook endpoint's signing secret from the Stripe dashboard in production.
STRIPE_WEBHOOK_SECRET=whsec_...
